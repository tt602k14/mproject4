<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.htdgym.app">

    <!-- Internet -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Camera (không bắt buộc thiết bị phải có) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- ❌ ĐÃ XÓA: READ / WRITE_EXTERNAL_STORAGE (deprecated Android 13+) -->

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Diagnostic Activity for Testing -->
        <activity
            android:name=".activities.DiagnosticActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />

        <!-- Splash (Main Entry Point) -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />

        <!-- Onboarding -->
        <activity
            android:name=".activities.LanguageSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.WelcomeActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- Main -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/AppTheme" />

        <!-- Auth -->
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false"
            android:parentActivityName=".activities.LoginActivity"
            android:theme="@style/AppTheme" />

        <activity
            android:name=".activities.ForgotPasswordActivity"
            android:exported="false"
            android:parentActivityName=".activities.LoginActivity" />

        <!-- Settings -->
        <activity
            android:name=".activities.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light" />

        <!-- Add -->
        <activity
            android:name=".activities.AddMemberActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".activities.AddWorkoutActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".activities.AddPaymentActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".activities.AddEquipmentActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- AI Coach -->
        <activity
            android:name=".activities.AICoachActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Community -->
        <activity
            android:name=".activities.CommunityActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Video -->
        <activity
            android:name=".activities.VideoActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />
        
        <activity
            android:name=".activities.VideoLibraryActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />
        
        <activity
            android:name=".activities.WorkoutLibraryActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light" />
        
        <activity
            android:name=".activities.VideoPlayerActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        
        <activity
            android:name=".activities.WorkoutSessionActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".activities.WorkoutActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />
        
        <activity
            android:name=".activities.TestWorkoutActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".activities.TrainingScheduleActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light" />
        
        <activity
            android:name=".activities.WorkoutDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.ProgramDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.ProgramPhaseDetailActivity"
            android:exported="false"
            android:parentActivityName=".activities.ProgramDetailActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.ProgramExerciseSessionActivity"
            android:exported="false"
            android:parentActivityName=".activities.ProgramPhaseDetailActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- Premium -->
        <activity
            android:name=".activities.PremiumActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- Admin Panel -->
        <activity
            android:name=".activities.AdminDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.AdminUserManagementActivity"
            android:exported="false"
            android:parentActivityName=".activities.AdminDashboardActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.AdminPremiumManagementActivity"
            android:exported="false"
            android:parentActivityName=".activities.AdminDashboardActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.AdminContentManagementActivity"
            android:exported="false"
            android:parentActivityName=".activities.AdminDashboardActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.AdminSystemSettingsActivity"
            android:exported="false"
            android:parentActivityName=".activities.AdminDashboardActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- New Premium Activities -->
        <activity
            android:name=".activities.HIITWorkoutActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.MuscleBuilderActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.ExerciseDetailActivity"
            android:exported="false"
            android:parentActivityName=".activities.WorkoutLibraryActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- Default Accounts -->
        <activity
            android:name=".activities.DefaultAccountsActivity"
            android:exported="false"
            android:parentActivityName=".activities.SettingsActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- Enhanced Features -->
        <activity
            android:name=".activities.CustomWorkoutBuilderActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.CalorieCalculatorActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.ProgressPhotosActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.PhotoDetailActivity"
            android:exported="false"
            android:parentActivityName=".activities.ProgressPhotosActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.PhotoComparisonActivity"
            android:exported="false"
            android:parentActivityName=".activities.ProgressPhotosActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.ProgramExerciseListActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.Program45DaysActivity"
            android:exported="false"
            android:parentActivityName=".activities.ProgramExerciseListActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- Smart Workout Planner -->
        <activity
            android:name=".activities.SmartWorkoutPlannerActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.GeneratedWorkoutActivity"
            android:exported="false"
            android:parentActivityName=".activities.SmartWorkoutPlannerActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".activities.WorkoutTemplatesActivity"
            android:exported="false"
            android:parentActivityName=".activities.SmartWorkoutPlannerActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <!-- File Provider for Camera -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.htdgym.app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
