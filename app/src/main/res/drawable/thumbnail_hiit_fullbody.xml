<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF9800"
                android:endColor="#F57C00"
                android:angle="135"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    
    <!-- Full body workout icon -->
    <item android:gravity="center">
        <vector
            android:width="64dp"
            android:height="64dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M12,2c1.1,0 2,0.9 2,2s-0.9,2 -2,2 -2,-0.9 -2,-2 0.9,-2 2,-2zM21,9h-6l-2,-2h-2l-2,2H3v2h1l2,7h2l2,-7h4l2,7h2l2,-7h1V9z"/>
        </vector>
    </item>
    
    <!-- HIIT text indicator -->
    <item android:gravity="top|center_horizontal" android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#80FFFFFF"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>