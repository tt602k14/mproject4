<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFA726"
                android:endColor="#FF8F00"
                android:angle="135"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    
    <!-- Person with arms -->
    <item android:gravity="center">
        <vector
            android:width="80dp"
            android:height="80dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M12,2c1.1,0 2,0.9 2,2s-0.9,2 -2,2 -2,-0.9 -2,-2 0.9,-2 2,-2zM8,7h8v2H8V7zM6,11h2v8H6V11zM16,11h2v8h-2V11zM10,11h4v8h-4V11z"/>
        </vector>
    </item>
    
    <!-- Shoulder muscles -->
    <item android:gravity="center">
        <vector
            android:width="80dp"
            android:height="40dp"
            android:viewportWidth="80"
            android:viewportHeight="40">
            <path
                android:fillColor="#80FFFFFF"
                android:pathData="M10,15 Q5,20 10,25 Q15,20 10,15 M70,15 Q65,20 70,25 Q75,20 70,15"/>
        </vector>
    </item>
</layer-list>