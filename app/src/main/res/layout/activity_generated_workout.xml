<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/gradient_primary">

            <!-- Back button -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_margin="16dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#30FFFFFF"
                android:padding="10dp"
                android:tint="@android:color/white" />

            <!-- Regenerate button -->
            <ImageView
                android:id="@+id/btn_regenerate"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_margin="16dp"
                android:src="@drawable/ic_refresh"
                android:background="@drawable/circle_button_bg"
                android:backgroundTint="#30FFFFFF"
                android:padding="10dp"
                android:tint="@android:color/white" />

            <!-- Center content -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖"
                    android:textSize="40sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Generated Workout"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Được tạo riêng cho bạn"
                    android:textColor="#CCE0FF"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Workout Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0F1628">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_workout_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Giảm Mỡ - Người Mới"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_workout_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Người mới • 🎯 Giảm mỡ • ⏰ 30 phút • 💪 6 bài"
                    android:textSize="13sp"
                    android:textColor="#8899BB"
                    android:layout_marginBottom="20dp" />

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_start_workout"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="🚀 BẮT ĐẦU"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:background="@color/primary_color"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn_save_workout"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="💾 Lưu lại"
                        android:textColor="#6FCF97"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/btn_outline_bg"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- AI Tips Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0A1A2A">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Lời khuyên từ AI Coach"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#6FCF97"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tv_ai_tips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Giữ nhịp tim cao trong suốt workout\n• Nghỉ ngắn giữa các set (30-45s)\n• Uống nước đều đặn\n• Kết hợp với chế độ ăn deficit calories"
                    android:textSize="13sp"
                    android:textColor="#8899BB"
                    android:lineSpacingExtra="6dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Exercises List -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0F1628">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💪 Danh sách bài tập"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_exercises"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
