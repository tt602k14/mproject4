<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#2C2C2C">

    <!-- Header với nút đóng -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF" />

    </RelativeLayout>

    <!-- Icon và Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_person"
            app:tint="#4CAF50"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng nhập / Đăng ký"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tab_login"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Đăng nhập"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/tab_selected_bg"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tab_register"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Đăng ký"
            android:textColor="#999999"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/tab_unselected_bg"
            android:layout_marginHorizontal="2dp" />

        <TextView
            android:id="@+id/tab_forgot"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Quên mật khẩu"
            android:textColor="#999999"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/tab_unselected_bg"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Form Container -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Login Form -->
            <LinearLayout
                android:id="@+id/form_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Email Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <!-- Email Input -->
                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="email@example.com"
                    android:textColorHint="#666666"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="24dp" />

                <!-- Password Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mật khẩu"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <!-- Password Input -->
                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="••••••"
                    android:textColorHint="#666666"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPassword"
                    android:layout_marginBottom="32dp" />

                <!-- Login Button -->
                <Button
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="→ Đăng nhập"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_green"
                    android:layout_marginBottom="24dp" />

                <!-- Social Login Text -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoặc đăng nhập với"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp" />

                <!-- Social Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btn_google"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="G Google"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:background="@drawable/button_google"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn_facebook"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="f Facebook"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:background="@drawable/button_facebook"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Register Form -->
            <LinearLayout
                android:id="@+id/form_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Name Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Họ tên"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_register_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nhập họ tên"
                    android:textColorHint="#666666"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="16dp" />

                <!-- Email Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_register_email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="email@example.com"
                    android:textColorHint="#666666"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="16dp" />

                <!-- Password Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mật khẩu"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_register_password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Tối thiểu 6 ký tự"
                    android:textColorHint="#666666"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPassword"
                    android:layout_marginBottom="32dp" />

                <!-- Register Button -->
                <Button
                    android:id="@+id/btn_register"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="→ Đăng ký"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_green"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>

            <!-- Forgot Password Form -->
            <LinearLayout
                android:id="@+id/form_forgot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Email Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_forgot_email"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="email@example.com"
                    android:textColorHint="#666666"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="32dp" />

                <!-- Reset Button -->
                <Button
                    android:id="@+id/btn_reset"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="→ Gửi link đặt lại"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/button_green"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>