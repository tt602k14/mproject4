<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB">

    <!-- ── HERO BANNER ── -->
    <RelativeLayout
        android:id="@+id/hero_banner"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#667eea">

        <!-- Gradient overlay layer (drawn via shape) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_hero_overlay" />

        <!-- Back button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_margin="12dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            app:tint="@android:color/white" />

        <!-- Title block bottom-left -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_program_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chương trình 30 ngày 🌱"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:shadowColor="#44000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4" />

            <TextView
                android:id="@+id/tv_program_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giai đoạn nền tảng cho người mới bắt đầu"
                android:textColor="#E0FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

        <!-- Stats row top-right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/tv_stat_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ngày"
                    android:textColor="#CCE0FF"
                    android:textSize="11sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:background="#44FFFFFF"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cơ bản"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="trình độ"
                    android:textColor="#CCE0FF"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <!-- ── TABS ── -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabSelectedTextColor="#667eea"
        app:tabTextColor="#999999"
        app:tabIndicatorColor="#667eea"
        app:tabIndicatorHeight="3dp"
        android:elevation="4dp" />

    <!-- ── CONTENT ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/recycler_exercises"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/layout_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp" />

        </ScrollView>

        <!-- Premium Lock -->
        <LinearLayout
            android:id="@+id/premium_lock_card"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="64sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nội dung Premium"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nâng cấp để mở khoá toàn bộ lịch trình 60 và 90 ngày"
                android:textSize="14sp"
                android:textColor="#888888"
                android:gravity="center"
                android:layout_marginBottom="28dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFD700">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👑  NÂNG CẤP PREMIUM"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:paddingHorizontal="28dp"
                    android:paddingVertical="14dp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
