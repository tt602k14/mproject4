<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_background"
    android:gravity="center"
    android:padding="32dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱️ Thời gian nghỉ ngơi"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginBottom="32dp"
        android:gravity="center" />

    <!-- Timer Display -->
    <androidx.cardview.widget.CardView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="140dp"
        app:cardElevation="8dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/primary">

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_timer"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_centerInParent="true"
                style="?android:attr/progressBarStyleHorizontal"
                android:progressDrawable="@drawable/circular_progress"
                android:background="@drawable/circular_progress_bg"
                android:max="100"
                android:progress="0" />

            <!-- Timer Text -->
            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="01:30"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:fontFamily="monospace" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:text="▶️ Bắt đầu"
            android:textColor="@android:color/white"
            android:background="@color/primary"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_pause"
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:text="⏸️ Tạm dừng"
            android:textColor="@color/primary"
            android:background="@drawable/btn_outline_bg"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Secondary Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:text="🔄 Reset"
            android:textColor="@color/secondary"
            android:background="@android:color/transparent"
            android:textStyle="bold"
            android:layout_marginEnd="24dp"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_close"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:text="❌ Đóng"
            android:textColor="@color/danger"
            android:background="@android:color/transparent"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Motivational Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💪 Nghỉ ngơi để tập tốt hơn!"
        android:textSize="16sp"
        android:textColor="@color/gray"
        android:layout_marginTop="32dp"
        android:gravity="center" />

</LinearLayout>