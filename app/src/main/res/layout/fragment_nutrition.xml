<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/gradient_header_bg"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥗 Dinh dưỡng"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theo dõi chế độ ăn uống hàng ngày"
                android:textSize="14sp"
                android:textColor="#E0FFFFFF"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Nutrition Goal Selection -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:backgroundTint="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Mục tiêu dinh dưỡng"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="16dp" />

                <Spinner
                    android:id="@+id/spinner_nutrition_goal"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_bg"
                    android:layout_marginBottom="20dp" />

                <!-- Daily Targets -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/rounded_bg_light"
                        android:padding="16dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/tv_daily_calories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1,800"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#6FCF97" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calo/ngày"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/rounded_bg_light"
                        android:padding="16dp"
                        android:layout_marginHorizontal="4dp">

                        <TextView
                            android:id="@+id/tv_protein_goal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="140g"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FF6B6B" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Protein"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/rounded_bg_light"
                        android:padding="16dp"
                        android:layout_marginHorizontal="4dp">

                        <TextView
                            android:id="@+id/tv_carb_goal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="150g"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#4ECDC4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Carb"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/rounded_bg_light"
                        android:padding="16dp"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/tv_fat_goal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="60g"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FFA726" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chất béo"
                            android:textSize="12sp"
                            android:textColor="#999999" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Water Tracker -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:backgroundTint="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💧 Theo dõi nước"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:id="@+id/tv_water_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đã uống: 3/8 cốc"
                        android:textSize="14sp"
                        android:textColor="#6FCF97"
                        android:textStyle="bold" />

                </LinearLayout>

                <GridLayout
                    android:id="@+id/grid_water_glasses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="4"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_reset_water"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:text="Đặt lại"
                    android:textSize="12sp"
                    android:backgroundTint="#E0E0E0"
                    android:textColor="#666666"
                    style="@style/Widget.Material3.Button.TextButton" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Meal Plan -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:backgroundTint="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🍽️ Thực đơn hôm nay"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <Button
                        android:id="@+id/btn_generate_meal_plan"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Tạo thực đơn"
                        android:textSize="12sp"
                        android:backgroundTint="#6FCF97"
                        style="@style/Widget.Material3.Button" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_meals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>