<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thêm thiết bị mới"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- TÊN THIẾT BỊ -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#1E1E1E"
            app:boxStrokeColor="#FF9800"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_equipment_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên thiết bị *"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- THƯƠNG HIỆU -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#1E1E1E"
            app:boxStrokeColor="#FF9800"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_equipment_brand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Thương hiệu"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- LOẠI THIẾT BỊ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loại thiết bị"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_equipment_category"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="#1E1E1E"
            android:padding="12dp" />

        <!-- TÌNH TRẠNG -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tình trạng"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_equipment_condition"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="#1E1E1E"
            android:padding="12dp" />

        <!-- GIÁ MUA -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#1E1E1E"
            app:boxStrokeColor="#FF9800"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_purchase_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Giá mua"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- NGÀY MUA -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#1E1E1E"
            app:boxStrokeColor="#FF9800"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_purchase_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ngày mua *"
                android:focusable="false"
                android:clickable="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- VỊ TRÍ -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#1E1E1E"
            app:boxStrokeColor="#FF9800"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_equipment_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Vị trí *"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- GHI CHÚ -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="#1E1E1E"
            app:boxStrokeColor="#FF9800"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_equipment_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ghi chú"
                android:minLines="3"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAAAAA" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Hủy"
                app:backgroundTint="#757575" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_equipment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Lưu"
                app:backgroundTint="#FF9800" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
